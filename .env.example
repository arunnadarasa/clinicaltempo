OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
PARALLEL_API_KEY=your_parallel_api_key_here
AGENTMAIL_API_KEY=your_agentmail_api_key_here
AGENTMAIL_BASE_URL=https://api.agentmail.to
# AgentMail MPP base URL for wallet-paid mode (mppx/client).
AGENTMAIL_MPP_BASE_URL=https://mpp.api.agentmail.to
AGENTMAIL_INBOX_ID=your_agentmail_inbox_id_here
# Legacy (no longer used by the server): AgentMail send is now
# POST /v0/inboxes/{inbox_id}/messages/send
AGENTMAIL_SEND_PATH=/v1/send
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_BASE_URL=https://maps.googleapis.com/maps/api
KICKSDB_API_KEY=your_kicksdb_api_key_here
KICKSDB_BASE_URL=https://kicksdb.mpp.tempo.xyz
KICKSDB_SEARCH_PATH=/v3/stockx/products
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_BASE_URL=https://weather.mpp.paywithlocus.com
OPENWEATHER_CURRENT_PATH=/data/2.5/weather
SUNO_API_KEY=your_suno_api_key_here
SUNO_BASE_URL=https://suno.mpp.paywithlocus.com
SUNO_GENERATE_PATH=/api/generate
# Optional legacy header auth; StablePhone primarily uses x402 + SIWX flows.
STABLEPHONE_API_KEY=
STABLEPHONE_BASE_URL=https://stablephone.dev
STABLEPHONE_CALL_PATH=/api/call
STABLEPHONE_STATUS_PATH=/api/call
STABLESOCIAL_BASE_URL=https://stablesocial.dev
STABLESOCIAL_INSTAGRAM_PROFILE_PATH=/api/instagram/profile
STABLESOCIAL_JOBS_PATH=/api/jobs
CARD_PROVIDER=laso
LASO_BASE_URL=https://laso.mpp.paywithlocus.com
LASO_MPP_PATH=/get-card
LASO_CARD_STATUS_PATH=/get-card-data
PORT=8787

# Tempo: testnet (42431, pathUSD) or mainnet (4217, USDC)
TMPO_TESTNET=true

# Payment scaffold (used when PAYMENT_MODE=mock or live)
PAYMENT_MODE=mock
MPP_CURRENCY=
MPP_RECIPIENT=0x742d35Cc6634c0532925a3b844bC9e7595F8fE00
MPP_DECIMALS=6
